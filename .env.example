# ============================================================================
# HotelConnect — environment variables
# Copy this file to ".env.local" and fill in the real values.
# .env.local is git-ignored and must NEVER be committed.
# ============================================================================

# From Supabase: Project Settings -> API
# The Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The "anon / public" key (the publishable one). Safe to expose in the browser
# because Row Level Security protects the data. NOT the service_role secret.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ----------------------------------------------------------------------------
# The two hidden role accounts (see supabase/SETUP.md). The user only ever types
# a PIN; the app uses the PIN as the password for the matching email below.
# These emails are just login identifiers — security comes from the PIN + RLS.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_RECEPTION_EMAIL=reception@pulizie-hotel.local
NEXT_PUBLIC_PULIZIE_EMAIL=pulizie@pulizie-hotel.local
